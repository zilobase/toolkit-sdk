{
  "name": "@zilobase/toolkit",
  "version": "0.1.2",
  "description": "Server-side TypeScript SDK for Zilobase Toolkit connectors and tools.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zilobase/toolkit-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/zilobase/toolkit-sdk#readme",
  "bugs": {
    "url": "https://github.com/zilobase/toolkit-sdk/issues"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "workerd": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/generated/api.d.ts",
      "default": "./dist/protocol.js"
    },
    "./vercel": {
      "workerd": {
        "types": "./dist/vercel/index.d.ts",
        "default": "./dist/vercel/index.js"
      },
      "browser": {
        "types": "./dist/vercel/browser.d.ts",
        "default": "./dist/vercel/browser.js"
      },
      "types": "./dist/vercel/index.d.ts",
      "default": "./dist/vercel/index.js"
    },
    "./vercel/metadata": {
      "types": "./dist/vercel/metadata.d.ts",
      "default": "./dist/vercel/metadata.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs && node --conditions=workerd --conditions=browser --test test/workerd-exports.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "ai": "^6.0.193"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
