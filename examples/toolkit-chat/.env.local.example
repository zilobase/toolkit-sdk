OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

TOOLKIT_API_KEY=
TOOLKIT_USER_ID=toolkit-chat-example
# Optional fallback destination when the connection flow is not opened as a popup.
# Its origin must be allowlisted for the Toolkit project.
TOOLKIT_RETURN_URL=

# Development only. Sends raw server-side tool failures to the chat UI.
TOOLKIT_SHOW_RAW_TOOL_ERRORS=false

# Required when TOOLKIT_WRITE_TOOLS is non-empty. Use a stable random secret.
TOOLKIT_APPROVAL_SECRET=

# Optional comma-separated write tool IDs. Read tools are enabled by default.
TOOLKIT_WRITE_TOOLS=
